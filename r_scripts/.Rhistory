#* Predict arrest probability
#* @param lat
#* @param lon
#* @param hour
#* @param night
#* @param density
#* @param risk
#* @get /predict
function(lat, lon, hour, night, density, risk){
# Convert input into dataframe
new_data <- data.frame(
Latitude = as.numeric(lat),
Longitude = as.numeric(lon),
Hour = as.numeric(hour),
Night = as.numeric(night),
Crime_Density = as.numeric(density),
Risk_Label = as.factor(risk)
)
# Prediction
prob <- predict(model, new_data, type = "response")
result <- ifelse(prob > 0.5, "Arrest Likely", "No Arrest")
return(list(
probability = round(prob, 3),
prediction = result
))
}
