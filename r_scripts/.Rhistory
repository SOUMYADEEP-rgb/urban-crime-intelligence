} else if (density_val > median_density) {
data$Risk_Label[data$Cluster == i] <- "Day Moderate Crime"
} else {
data$Risk_Label[data$Cluster == i] <- "Day Low Crime"
}
}
# -------------------------------
# STEP 7: Visualization
# -------------------------------
ggplot(data, aes(x = Longitude, y = Latitude, color = Risk_Label)) +
geom_point(alpha = 0.5) +
ggtitle("Crime Clusters with Risk Labels")
# -------------------------------
# STEP 8: Save Output
# -------------------------------
write.csv(data, "data/processed/clustered_data_modified.csv", row.names = FALSE)
cat("Clustering completed.\n")
library(dplyr)
library(caret)
setwd("C:/Users/soumy/Desktop/urban-crime-intelligence")
cat("Loading clustered data...\n")
data <- read.csv("data/processed/clustered_data_modified.csv")
# -------------------------------
# STEP 1: Prepare Data
# -------------------------------
data$Arrest <- as.factor(data$Arrest)
data$Risk_Label <- as.factor(data$Risk_Label)
model_data <- data %>%
select(Latitude, Longitude, Hour, Night, Crime_Density, Risk_Label, Arrest)
# -------------------------------
# STEP 2: Train-Test Split
# -------------------------------
set.seed(123)
trainIndex <- createDataPartition(model_data$Arrest, p = 0.8, list = FALSE)
train_data <- model_data[trainIndex, ]
test_data  <- model_data[-trainIndex, ]
# -------------------------------
# STEP 3: Train Model (Logistic Regression)
# -------------------------------
cat("Training model...\n")
model <- glm(Arrest ~ ., data = train_data, family = "binomial")
# -------------------------------
# STEP 4: Predictions
# -------------------------------
probabilities <- predict(model, test_data, type = "response")
predictions <- ifelse(probabilities > 0.5, 1, 0)
predictions <- as.factor(predictions)
# -------------------------------
# STEP 5: Evaluation
# -------------------------------
conf_matrix <- confusionMatrix(predictions, test_data$Arrest)
print(conf_matrix)
# -------------------------------
# STEP 6: Save Model
# -------------------------------
dir.create("models", showWarnings = FALSE)
saveRDS(model, "models/arrest_model.rds")
cat("Classification completed.\n")
