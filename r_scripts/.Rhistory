source("~/LAB3.R")
data <- data.frame(
Country_State = c("India","India","India",
"Tamil Nadu","Tamil Nadu","Tamil Nadu",
"Kerala","Kerala","Kerala",
"Maharashtra","Maharashtra","Maharashtra"),
Year = c(2018,2019,2020,
2018,2019,2020,
2018,2019,2020,
2018,2019,2020),
Literacy_Male = c(82.1,83.0,84.2,87.5,88.3,89.0,96.1,96.4,96.8,90.4,91.1,92.0),
Literacy_Female = c(65.5,66.8,68.1,73.2,74.6,75.9,92.3,92.8,93.2,79.2,80.6,82.0),
Enrollment_Primary = c(95.2,96.0,94.5,98.1,98.5,97.8,99.2,99.4,99.0,97.0,97.6,96.8),
Enrollment_Secondary = c(74.3,75.6,73.9,82.4,83.7,82.9,88.6,89.1,88.4,80.5,81.9,80.7),
Dropout_Rate = c(4.8,4.5,5.2,2.6,2.4,2.9,1.2,1.1,1.4,3.1,2.9,3.4)
)
source("~/LAB3.R")
source("~/LAB3.R")
source("~/LAB3.R")
source("~/LAB3.R")
source("~/LAB3.R")
source("~/LAB3.R")
filtered_data <- data %>%
mutate(
Literacy_Gap = Literacy_Male - Literacy_Female,
Enrollment_Change = Enrollment_Primary - Enrollment_Secondary
) %>%
filter(Literacy_Gap > 10, Dropout_Rate < 4)
print(filtered_data)
state_summary <- data %>%
group_by(Country_State) %>%
summarise(
Avg_Male = mean(Literacy_Male),
Avg_Female = mean(Literacy_Female),
Avg_Dropout = mean(Dropout_Rate),
Avg_Gap = Avg_Male - Avg_Female
) %>%
arrange(desc(Avg_Gap))
top_two <- head(state_summary, 2)
print(top_two)
