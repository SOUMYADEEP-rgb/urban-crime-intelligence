select(year, month, day, carrier, origin, dep_delay, arr_delay) %>%
filter(!is.na(dep_delay), !is.na(arr_delay), origin == "JFK") %>%
mutate(total_delay = dep_delay + arr_delay) %>%
filter(dep_delay < 0, arr_delay > 0) %>%
arrange(month, desc(total_delay))
