clean_data <- starwars %>%
filter(!is.na(height), !is.na(mass), !is.na(gender)) %>%
mutate(BMI_like = mass / (height/100)^2)
summary(clean_data$BMI_like)
top_species <- clean_data %>%
group_by(species) %>%
summarise(
Avg_Height = mean(height, na.rm=TRUE),
Avg_Mass = mean(mass, na.rm=TRUE),
Avg_BMI = mean(BMI_like, na.rm=TRUE)
) %>%
arrange(desc(Avg_BMI)) %>%
head(3)
top_species
species_gender_summary <- clean_data %>%
group_by(species, gender) %>%
summarise(
Avg_Height = mean(height, na.rm=TRUE),
Avg_Mass = mean(mass, na.rm=TRUE)
)
species_gender_summary
species_gender_summary <- clean_data %>%
group_by(species, gender) %>%
summarise(
Avg_Height = mean(height, na.rm=TRUE),
Avg_Mass = mean(mass, na.rm=TRUE)
)
species_gender_summary
region_lookup <- data.frame(
homeworld = c("Tatooine","Alderaan","Naboo","Coruscant"),
Region = c("Outer Rim","Core Worlds","Mid Rim","Core Worlds")
)
# Left Join
left_join_data <- left_join(starwars, region_lookup, by="homeworld")
# Inner Join
inner_join_data <- inner_join(starwars, region_lookup, by="homeworld")
# Full Join
full_join_data <- full_join(starwars, region_lookup, by="homeworld")
long_data <- clean_data %>%
select(species, height, mass, BMI_like) %>%
gather(Attribute, Value, height: BMI_like)
summary_data <- long_data %>%
group_by(species, Attribute) %>%
summarise(Mean_Value = mean(Value, na.rm=TRUE))
wide_summary <- summary_data %>%
spread(Attribute, Mean_Value)
ggplot(summary_data, aes(x=species, y=Mean_Value, fill=Attribute)) +
geom_bar(stat="identity", position="dodge") +
theme(axis.text.x = element_text(angle=90, hjust=1))
