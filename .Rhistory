View(flights)
flights_small <- flights %>%
select(year, month, day, dep_delay, arr_delay)
flights_long <- flights_small %>%
pivot_longer(
cols = c(dep_delay, arr_delay),
names_to = "delay_type",
values_to = "delay_minutes"
)
View(flights_long)
flights_wide <- flights_long %>%
pivot_wider(
names_from = delay_type,
values_from = delay_minutes
)
glimpse(flights_wide)
flights_per_month <- flights %>%
group_by(month) %>%
summarise(total_flights = n())
ggplot(flights_per_month, aes(x = month, y = total_flights)) +
geom_col() +
labs(
title = "Number of Flights per Month (2013)",
x = "Month",
y = "Total Flights"
)
flights_wide <- flights_long %>%
pivot_wider(
names_from = delay_type,
values_from = delay_minutes
)
View(flights_wide)
