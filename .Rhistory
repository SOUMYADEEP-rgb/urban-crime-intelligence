library(dplyr)
library(ggplot2)
library(caret)
cat("Loading dataset...\n")
data <- read.csv("urban-crime-intelligence/data/processed/clean_data.csv")
getwd()
setwd("C:/Users/soumy/Desktop/urban-crime-intelligence")
cat("Loading dataset...\n")
data <- read.csv("data/processed/clean_data.csv")
cat("Creating crime density feature...\n")
data <- data %>%
group_by(Latitude, Longitude) %>%
mutate(Crime_Density = n()) %>%
ungroup()
cluster_data <- data %>%
select(Latitude, Longitude, Hour, Night, Crime_Density)
cat("Scaling data...\n")
scaled_data <- scale(cluster_data)
cat("Running K-Means...\n")
set.seed(123)
kmeans_model <- kmeans(scaled_data, centers = 4, nstart = 25)
data$Cluster <- kmeans_model$cluster
cat("Cluster Summary:\n")
cluster_summary <- data %>%
group_by(Cluster) %>%
summarise(
Avg_Hour = mean(Hour),
Night_Ratio = mean(Night),
Avg_Density = mean(Crime_Density),
Count = n()
)
print(cluster_summary)
cat("Assigning Risk Labels...\n")
data$Risk_Label <- NA
for (i in 1:4) {
night_val <- cluster_summary$Night_Ratio[i]
density_val <- cluster_summary$Avg_Density[i]
if (night_val > 0.5 & density_val > median(cluster_summary$Avg_Density)) {
data$Risk_Label[data$Cluster == i] <- "Night High Crime"
} else if (night_val > 0.5 & density_val <= median(cluster_summary$Avg_Density)) {
data$Risk_Label[data$Cluster == i] <- "Night Low Crime"
} else if (night_val <= 0.5 & density_val > median(cluster_summary$Avg_Density)) {
data$Risk_Label[data$Cluster == i] <- "Day High Crime"
} else {
data$Risk_Label[data$Cluster == i] <- "Day Low Crime"
}
}
cat("Plotting clusters...\n")
ggplot(data, aes(x = Longitude, y = Latitude, color = Risk_Label)) +
geom_point(alpha = 0.5) +
ggtitle("Crime Clusters with Risk Labels")
write.csv(data, "data/processed/clustered_data.csv", row.names = FALSE)
cat("Clustering completed and saved.\n")
library(dplyr)
library(ggplot2)
library(caret)
getwd()
setwd("C:/Users/soumy/Desktop/urban-crime-intelligence")
cat("Loading dataset...\n")
data <- read.csv("data/processed/clean_data.csv")
# -------------------------------
# STEP 1: Create Crime Density
# -------------------------------
cat("Creating crime density feature...\n")
data <- data %>%
group_by(Latitude, Longitude) %>%
mutate(Crime_Density = n()) %>%
ungroup()
# -------------------------------
# STEP 2: Select Features
# -------------------------------
cluster_data <- data %>%
select(Latitude, Longitude, Hour, Night, Crime_Density)
# -------------------------------
# STEP 3: Scaling
# -------------------------------
cat("Scaling data...\n")
scaled_data <- scale(cluster_data)
# -------------------------------
# STEP 4: K-Means Clustering (K=4)
# -------------------------------
cat("Running K-Means...\n")
set.seed(123)
kmeans_model <- kmeans(scaled_data, centers = 4, nstart = 25)
data$Cluster <- kmeans_model$cluster
# -------------------------------
# STEP 5: Understand Clusters
# -------------------------------
cat("Cluster Summary:\n")
cluster_summary <- data %>%
group_by(Cluster) %>%
summarise(
Avg_Hour = mean(Hour),
Night_Ratio = mean(Night),
Avg_Density = mean(Crime_Density),
Count = n()
)
print(cluster_summary)
# -------------------------------
# STEP 6: Assign Meaningful Labels
# -------------------------------
cat("Assigning Risk Labels...\n")
data$Risk_Label <- NA
for (i in 1:4) {
night_val <- cluster_summary$Night_Ratio[i]
density_val <- cluster_summary$Avg_Density[i]
if (night_val > 0.5 & density_val > median(cluster_summary$Avg_Density)) {
data$Risk_Label[data$Cluster == i] <- "Night High Crime"
} else if (night_val > 0.5 & density_val <= median(cluster_summary$Avg_Density)) {
data$Risk_Label[data$Cluster == i] <- "Night Low Crime"
} else if (night_val <= 0.5 & density_val > median(cluster_summary$Avg_Density)) {
data$Risk_Label[data$Cluster == i] <- "Day High Crime"
} else {
data$Risk_Label[data$Cluster == i] <- "Day Low Crime"
}
}
# -------------------------------
# STEP 7: Visualization
# -------------------------------
cat("Plotting clusters...\n")
ggplot(data, aes(x = Longitude, y = Latitude, color = Risk_Label)) +
geom_point(alpha = 0.5) +
ggtitle("Crime Clusters with Risk Labels")
# -------------------------------
# STEP 8: Save Output
# -------------------------------
write.csv(data, "data/processed/clustered_data.csv", row.names = FALSE)
cat("Clustering completed and saved.\n")
write.csv(data, "data/processed/clustered_data.csv", row.names = FALSE)
