inner_join_data <- clean_data %>%
inner_join(region_lookup, by = "homeworld")
View(inner_join_data)
full_join_data <- clean_data %>%
full_join(region_lookup, by = "homeworld")
View(full_join_data)
#PART5
long_data <- clean_data %>%
gather(key = "Attribute", value = "Value",
height, mass, BMI_like)
View(long_data)
summary_long <- long_data %>%
group_by(species, Attribute) %>%
summarise(avg_value = mean(Value), .groups = "drop")
wide_summary <- summary_long %>%
spread(Attribute, avg_value)
View(wide_summary)
ggplot(summary_long, aes(x = species, y = avg_value, fill = Attribute)) +
geom_bar(stat = "identity", position = "dodge") +
theme(axis.text.x = element_text(angle = 90)) +
labs(title = "Comparison of Attributes Across Species")
