install.packages(c("httr", "jsonlite", "ggplot2", "leaflet"))
library(httr)
library(jsonlite)
library(ggplot2)
library(leaflet)
url <- "https://api.open-meteo.com/v1/forecast?latitude=13.08&longitude=80.27&current_weather=true"
response <- GET(url)
json_data <- content(response, as = "text")
print(json_data)
weather_list <- fromJSON(json_data)
str(weather_list)
current_weather <- weather_list$current_weather
weather_df <- as.data.frame(current_weather)
print(weather_df)
weather_list_again <- as.list(weather_df)
str(weather_list_again)
ggplot(weather_df, aes(x = windspeed, y = temperature)) +
geom_point(size = 4) +
labs(
title = "Temperature vs Wind Speed",
x = "Wind Speed",
y = "Temperature"
) +
theme_minimal()
lat <- weather_list$latitude
lon <- weather_list$longitude
popup_text <- paste(
"Temperature:", weather_df$temperature, "<br>",
"Wind Speed:", weather_df$windspeed, "<br>",
"Weather Code:", weather_df$weathercode
)
leaflet() %>%
addTiles() %>%
addMarkers(
lng = lon,
lat = lat,
popup = popup_text
)
lat <- weather_list$latitude
lon <- weather_list$longitude
popup_text <- paste(
